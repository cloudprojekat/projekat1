# =============================================
# NEOPTIMIZOVANA VERZIJA (single-stage)
# Koristi se SAMO za poređenje veličine slike!
# NE koristiti ovu verziju u produkciji.
# =============================================
FROM node:18

WORKDIR /app

COPY package*.json ./

# Instalira SVE zavisnosti (uključujući devDependencies)
RUN npm install

COPY src/ ./src/

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

CMD ["node", "src/index.js"]